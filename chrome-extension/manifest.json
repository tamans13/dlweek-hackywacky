{
  "manifest_version": 3,
  "name": "Brainosaur Tab Tracker",
  "version": "1.0.0",
  "description": "Tracks tab switching to help Brainosaur measure focus vs distraction",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Brainosaur"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:3000/*",
        "http://localhost:5173/*",
        "http://127.0.0.1:3000/*",
        "http://127.0.0.1:5173/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "overlay.css"
      ],
      "js": [
        "overlay.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
