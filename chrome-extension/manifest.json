{
  "manifest_version": 3,
  "name": "Brainosaur Tab Tracker",
  "version": "1.0.0",
  "description": "Tracks tab switching to help Brainosaur measure focus vs distraction",
  "permissions": ["tabs", "activeTab"],
  "host_permissions": [
    "http://localhost:*/*",
    "http://127.0.0.1:*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:5173/*",
        "http://127.0.0.1:3000/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
