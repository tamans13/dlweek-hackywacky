{
  "manifest_version": 3,
  "name": "Brainosaur Tab Tracker",
  "version": "1.0.0",
  "description": "Tracks tab switching to help Brainosaur measure focus vs distraction",
  "permissions": [
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Brainosaur"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "overlay.css"
      ],
      "js": [
        "overlay.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "crying-dino.mp4"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
